# Switch between the local Anvil demo and the public Sepolia demo.
VITE_SWAGMI_DEMO_NETWORK=local

# Local demo defaults
VITE_SWAGMI_LOCAL_RPC_URL=http://127.0.0.1:8545
VITE_SWAGMI_LOCAL_CONTRACT_ADDRESS=

