{
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@": ["./src"],
      "@/*": ["./src/*"]
    },
    "types": ["vite/client"]
  },
  "extends": "../tsconfig.json",
  "include": [
    "src",
    "tests",
    "**.ts",
    "**.tsx",
    "package.json"
  ]
}
